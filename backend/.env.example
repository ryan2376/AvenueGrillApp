# Avenue Grill backend — environment template.
# Copy the values you need into your run configuration / shell. NEVER commit real secrets.

# Server
PORT=8080

# Database (matches infra/docker-compose.yml defaults for local dev)
DATABASE_URL=jdbc:postgresql://localhost:5434/avenuegrill
DATABASE_USERNAME=avenuegrill
DATABASE_PASSWORD=avenuegrill

# CORS — comma-separated allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Payments (Phase 4) — provider-agnostic layer. See docs/08-MPESA-INTEGRATION.md
PAYMENT_PROVIDER=none
# Aggregator / Jenga / Daraja credentials get added here when Phase 4 lands.
